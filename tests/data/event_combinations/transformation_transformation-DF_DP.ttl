@base <http://example.org/id/ekg/aggregated_traces/> .
@prefix : <http://example.org/def/ekg/aggregated_traces/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<1> a :Transformation ;
    :inputQuantity <1/inputQuantity1>,
        <1/inputQuantity2> ;
    :outputQuantity <1/outputQuantity> ;
    :timestamp 1 ;
    :directlyFollows <2> .

<1/inputQuantity1> :amount 5 ;
    :class <Lot0>,
        <lotModel/0> .

<1/inputQuantity2> :amount 10 ;
    :class <MaterialLot0>,
        <material/0> .

<1/outputQuantity> :amount 5 ;
    :class <Lot0>,
        <lotModel/1> .

<2> a :Transformation ;
    :inputQuantity <2/inputQuantity1>,
        <2/inputQuantity2> ;
    :outputQuantity <2/outputQuantity> ;
    :timestamp 2 ;
    :directlyPrecedes <1> .

<2/inputQuantity1> :amount 5 ;
    :class <Lot0>,
        <lotModel/1> .

<2/inputQuantity2> :amount 5 ;
    :class <MaterialLot1>,
        <material/1> .

<2/outputQuantity> :amount 5 ;
    :class <Lot0>,
        <lotModel/2> .

<Lot0> a :AggregatedEntity .

<Lot1> a :AggregatedEntity .

<MaterialLot0> a :AggregatedEntity .

<MaterialLot1> a :AggregatedEntity .

<lotModel/0> a :Product .

<lotModel/1> a :Product .

<lotModel/2> a :Product .

<material/0> a :Product .

<material/1> a :Product .

<6b5360c53501c3174ef3e455bc525509> a :DirectlyFollows,
        :DirectlyFollows_AggregatedEntity ;
    :amount 5 ;
    :class <Lot0>,
        <lotModel/1> ;
    :source <1> ;
    :target <2> .

<6923774424a5a3ffd1346ff7fef4ad9c> a :DirectlyPrecedes,
        :DirectlyPrecedes_AggregatedEntity ;
    :amount 5 ;
    :class <Lot0>,
        <lotModel/1> ;
    :source <2> ;
    :target <1> .
