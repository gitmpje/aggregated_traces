@base <http://example.org/id/ekg/aggregated_traces/> .
@prefix : <http://example.org/def/ekg/aggregated_traces/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<1> a :Aggregation ;
    :action "DELETE" ;
    :parentEntity <Lot0> ;
    :childEntity <Lot1>,
        <Lot2> ;
    :childQuantity <1/childQuantity1>,
        <1/childQuantity2> ;
    :timestamp 1 .

<1/childQuantity1> :amount 5 ;
    :class <Lot1>,
        <lotModel/0> .

<1/childQuantity2> :amount 5 ;
    :class <Lot2>,
        <lotModel/0> .

<2> a :Object ;
    :entity <Lot1> ;
    :quantity <2/quantity> ;
    :timestamp 2 .

<2/quantity> :amount 5 ;
    :class <Lot1>,
        <lotModel/1> .

<3> a :Object ;
    :entity <Lot2> ;
    :quantity <3/quantity> ;
    :timestamp 3 .

<3/quantity> :amount 5 ;
    :class <Lot2>,
        <lotModel/1> .

<Lot0> a :AggregatedEntity .

<Lot1> a :AggregatedEntity .

<Lot2> a :AggregatedEntity .

<lotModel/0> a :Product .

<lotModel/1> a :Product .
