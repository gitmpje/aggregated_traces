@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<1> a :Object ;
    :entity <Lot0> ;
    :quantity <1/quantity> ;
    :timestamp 1 ;
    :directlyFollows <2> .

<1/quantity> :amount 5 ;
    :class <Lot0>,
        <lotModel/0> .

<2> a :Object ;
    :entity <Lot0> ;
    :quantity <2/quantity> ;
    :timestamp 2 ;
    :directlyPrecedes <1> .

<2/quantity> :amount 5 ;
    :class <Lot0>,
        <lotModel/1> .

<Lot0> a :AggregatedEntity .

<lotModel/0> a :Product .

<lotModel/1> a :Product .

<6b5360c53501c3174ef3e455bc525509> a :DirectlyFollows,
        :DirectlyFollows_AggregatedEntity ;
    :amount 5 ;
    :class <Lot0>,
        <lotModel/0> ;
    :source <1> ;
    :target <2> .

<6923774424a5a3ffd1346ff7fef4ad9c> a :DirectlyPrecedes,
        :DirectlyPrecedes_AggregatedEntity ;
    :amount 5 ;
    :class <Lot0>,
