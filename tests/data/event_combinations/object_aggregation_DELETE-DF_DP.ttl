@base <http://example.org/id/ekg/aggregated_traces/> .
@prefix : <http://example.org/def/ekg/aggregated_traces/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<1> a :Object ;
    :entity <Lot0> ;
    :quantity <1/quantity> ;
    :timestamp 1 .

<1/quantity> :amount 10 ;
    :class <Lot0>,
        <lotModel/0> .

<2> a :Aggregation ;
    :action "DELETE" ;
    :parentEntity <Lot0> ;
    :childEntity <Lot1>,
        <Lot2> ;
    :childQuantity <2/childQuantity1>,
        <2/childQuantity2> ;
    :timestamp 2 .

<2/childQuantity1> :amount 5 ;
    :class <Lot1>,
        <lotModel/1> .

<2/childQuantity2> :amount 5 ;
    :class <Lot2>,
        <lotModel/1> .

<Lot0> a :AggregatedEntity .

<Lot1> a :AggregatedEntity .

<Lot2> a :AggregatedEntity .

<lotModel/0> a :Product .

<lotModel/1> a :Product .

<6923774424a5a3ffd1346ff7fef4ad9c> a :DirectlyPrecedes,
        :DirectlyPrecedes_AggregatedEntity ;
    :amount 10 ;
    :class <Lot0>,
        <lotModel/0> ;
    :source <2> ;
    :target <1> .

<6b5360c53501c3174ef3e455bc525509> a :DirectlyFollows,
        :DirectlyFollows_AggregatedEntity ;
    :amount 10 ;
    :class <Lot0>,
        <lotModel/0> ;
    :source <1> ;
    :target <2> .
